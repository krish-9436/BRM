# Step 1: Clone the repository
git clone https://github.com/username/sample-repo.git

# Step 2: Move into the repository folder
cd sample-repo

# Step 3: Check existing branches
git branch

# Step 4: Create a new branch
git branch feature-branch

# Step 5: Switch to the new branch
git checkout feature-branch

# Step 6: Create a new file for the feature
echo "This is a new feature file" > feature.txt

# Step 7: Check repository status
git status

# Step 8: Add file to staging area
git add feature.txt

# Step 9: Commit the changes
git commit -m "Added feature file"

# Step 10: Push feature branch to GitHub
git push origin feature-branch

# Step 11: Switch back to main branch
git checkout main

# Step 12: Merge feature branch into main
git merge feature-branch

# Step 13: Push updated main branch to GitHub
git push origin main
